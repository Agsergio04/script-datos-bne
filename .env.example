# .env.example - Configuración de ejemplo para el proyecto

# Base de Datos
POSTGRES_DB=bne_db
POSTGRES_USER=bne_user
POSTGRES_PASSWORD=bne_password_123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Flask/Backend
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=dev_secret_key_change_in_production
DATABASE_URL=postgres://bne_user:bne_password_123@db:5432/bne_db

# Frontend
REACT_APP_API_BASE_URL=http://localhost:5000

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
